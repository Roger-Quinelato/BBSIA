# URL do Ollama local
OLLAMA_URL=http://localhost:11434

# Modelo padrao para respostas
DEFAULT_MODEL=llama3.1:8b

# Modelo de embedding usado no pipeline
EMBEDDING_MODEL=paraphrase-multilingual-mpnet-base-v2

# Top-K padrao para recuperacao de chunks
TOP_K=5
MAX_CONTEXT_CHUNKS=3
MAX_CHARS_PER_CHUNK=700
OLLAMA_TIMEOUT_SEC=300
OLLAMA_NUM_PREDICT=120
OLLAMA_NUM_CTX=2048

# Retrieval hibrido (dense + sparse + RRF)
HYBRID_DENSE_CANDIDATES=40
HYBRID_SPARSE_CANDIDATES=80
RRF_K=60

# Re-ranking opcional (mais qualidade, mais latencia)
ENABLE_RERANKER=false
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_CANDIDATES=20

# CORS (origens separadas por virgula)
CORS_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:8501,http://localhost:8502,http://localhost:8000

# Se definido, exige header X-API-Key em endpoints da API (exceto /status e docs)
API_KEY=

# Rate limit por IP
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SEC=60

# Tamanho maximo de upload por arquivo (em MB)
MAX_UPLOAD_SIZE_MB=50
