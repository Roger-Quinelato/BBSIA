# URL do Ollama local
OLLAMA_URL=http://localhost:11434

# Modelo padrao para respostas
DEFAULT_MODEL=qwen3.5:7b-instruct
ALLOWED_LLM_MODELS=qwen3.5:7b-instruct
ALLOW_REMOTE_OLLAMA=false

# Modelo de embedding usado no pipeline
EMBEDDING_MODEL=intfloat/multilingual-e5-large
EMBEDDING_DIM=1024
HF_LOCAL_FILES_ONLY=true
PRELOAD_RAG_ON_STARTUP=true
PRELOAD_RERANKER_ON_STARTUP=false
RAG_HEALTH_LOAD_ON_STATUS=false

# Top-K padrao para recuperacao de chunks
TOP_K=5
MAX_CONTEXT_CHUNKS=6
MAX_CHARS_PER_CHUNK=700
OLLAMA_TIMEOUT_SEC=300
OLLAMA_NUM_PREDICT=512
OLLAMA_NUM_CTX=8192

# Retrieval hibrido (dense + sparse + RRF)
HYBRID_DENSE_CANDIDATES=40
HYBRID_SPARSE_CANDIDATES=80
RRF_K=60
MIN_DENSE_SCORE_PERCENT=18

# Re-ranking local apos RRF (mais qualidade, mais latencia)
ENABLE_RERANKER=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_CANDIDATES=20
RERANKER_TOP_N=3
RERANKER_MAX_LENGTH=512

# CORS (origens separadas por virgula)
CORS_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:8501,http://localhost:8502,http://localhost:8000

# Se definido, exige header X-API-Key em endpoints da API (exceto /status e docs)
API_KEY=
READ_API_KEY=
ADMIN_API_KEY=

# Rate limit por IP
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SEC=60

# Tamanho maximo de upload por arquivo (em MB)
MAX_UPLOAD_SIZE_MB=50
MAX_PDF_PAGES=300
MAX_PDF_EXTRACTED_CHARS=2000000
PDF_VALIDATION_TIMEOUT_SEC=30
